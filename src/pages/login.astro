---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthCard from "../components/auth/AuthCard.astro";
import Toast from "../components/ui/Toast.astro";

const loginScripts = [
  "/js/utils/db.js",
  "/js/utils/auth.js",
  "/js/utils/toast.js",
];
---
<BaseLayout title="World Cup Collector — UES · Login" extraScripts={loginScripts}>
  <Fragment slot="head">
    <link rel="stylesheet" href="/css/auth.css"/>
    <style>
      .file-drop {
        display:block;cursor:pointer;border:1.5px dashed rgba(0,212,255,0.3);
        border-radius:8px;padding:0.8rem 1rem;text-align:center;
        color:#6677aa;font-size:0.8rem;transition:border-color 0.2s;
      }
      .file-drop:hover { border-color:rgba(0,212,255,0.7); color:#00d4ff; }
      .file-drop.has-file { border-color:#00d4ff; color:#00d4ff; }

      #welcome-anim {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: none;
        align-items: center;
        justify-content: center;
        background: #000;
        opacity: 0;
        transition: opacity 0.35s ease;
      }
      #welcome-anim.visible {
        display: flex;
        opacity: 1;
      }
      #welcome-anim video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .tutorial-overlay {
        position: fixed; inset: 0; z-index: 10000;
        background: rgba(5,8,14,0.88);
        backdrop-filter: blur(6px);
        display: flex; align-items: center; justify-content: center;
        padding: 1.25rem;
        opacity: 0; pointer-events: none;
        transition: opacity 0.3s ease;
      }
      .tutorial-overlay.show { opacity: 1; pointer-events: all; }
      .tutorial-card {
        position: relative;
        width: 100%; max-width: 440px;
        background: var(--bg-card, #131d2e);
        border: 1px solid var(--border-bright, #2a4060);
        border-radius: var(--radius-lg, 20px);
        box-shadow: 0 8px 40px rgba(0,0,0,0.6);
        padding: 2rem 1.75rem 1.5rem;
        text-align: center;
        transform: translateY(14px) scale(0.98);
        transition: transform 0.3s ease;
      }
      .tutorial-overlay.show .tutorial-card { transform: translateY(0) scale(1); }
      .tutorial-skip {
        position: absolute; top: 0.85rem; right: 1rem;
        background: none; border: none; cursor: pointer;
        color: var(--text-secondary, #7a8fa8);
        font-family: 'Barlow Condensed', sans-serif;
        font-size: 0.75rem; letter-spacing: 1px; text-transform: uppercase;
      }
      .tutorial-skip:hover { color: var(--accent, #00d4ff); }
      .tutorial-card h2 {
        font-family: 'Bebas Neue', cursive;
        font-size: 1.5rem; letter-spacing: 1.5px;
        color: var(--accent, #00d4ff);
        margin-bottom: 0.6rem;
      }
      .tutorial-card p {
        color: var(--text-secondary, #7a8fa8);
        font-size: 0.92rem; line-height: 1.55;
        min-height: 3.2em;
      }
      .tutorial-dots {
        display: flex; justify-content: center; gap: 6px;
        margin: 1.25rem 0 1.4rem;
      }
      .tutorial-dot {
        width: 7px; height: 7px; border-radius: 50%;
        background: var(--border-bright, #2a4060);
        transition: background 0.2s, transform 0.2s;
      }
      .tutorial-dot.active { background: var(--accent, #00d4ff); transform: scale(1.25); }
      .tutorial-actions { display: flex; gap: 0.6rem; }
      .tutorial-actions .btn { margin-top: 0; flex: 1; }
      .tutorial-actions .btn-secondary { flex: 0 0 auto; padding: 0.75rem 1.1rem; }

      .pass-field-wrap {
        position: relative;
        display: flex;
        align-items: center;
      }
      .pass-field-wrap input {
        width: 100%;
        padding-right: 2.6rem;
      }
      .pass-toggle-btn {
        position: absolute;
        right: 0.6rem;
        top: 50%;
        transform: translateY(-50%);
        background: none;
        border: none;
        cursor: pointer;
        font-size: 1rem;
        line-height: 1;
        padding: 0.3rem;
        opacity: 0.6;
        transition: opacity 0.2s;
      }
      .pass-toggle-btn:hover { opacity: 1; }
    </style>
  </Fragment>

  <div class="splash-loader" id="splash">
    <img src="/icons/icon-192.png" class="splash-ball" style="width:80px;height:80px;border-radius:50%;object-fit:cover;" alt="WCC Logo"/>
    <p class="splash-text">Verificando sesión…</p>
  </div>

  <div class="auth-bg">
    <div class="auth-orb orb-1"></div>
    <div class="auth-orb orb-2"></div>
    <div class="auth-grid"></div>
  </div>

  <AuthCard />

  <Toast />

  <Fragment slot="scripts">
    <script src="/js/auth-page.js" is:inline></script>
    <script src="/js/sw-register-simple.js" is:inline></script>
  </Fragment>
</BaseLayout>
