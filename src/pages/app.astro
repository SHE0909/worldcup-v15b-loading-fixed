  <script is:inline>

  (function() {
    const drawer  = document.getElementById('app-drawer');
    const overlay = document.getElementById('drawer-overlay');
    const btnOpen = document.getElementById('btn-drawer-open');
    const btnClose= document.getElementById('btn-drawer-close');
    const btnLogoutDrawer = document.getElementById('btn-drawer-logout');

    // Track drawer state explicitly to avoid CSS/JS desync bugs
    let _drawerOpen = false;

    function openDrawer() {
      _drawerOpen = true;
      drawer.classList.add('open');
      overlay.classList.add('visible');
      overlay.style.pointerEvents = 'auto';
      btnOpen?.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeDrawer() {
      _drawerOpen = false;
      drawer.classList.remove('open');
      overlay.classList.remove('visible');
      overlay.style.pointerEvents = 'none';
      btnOpen?.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    // Always start closed and ensure body overflow is clean
    closeDrawer();

    btnOpen?.addEventListener('click', openDrawer);
    btnClose?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    drawer?.querySelectorAll('.drawer-nav-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        // Sync active state
        drawer.querySelectorAll('.drawer-nav-btn').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        closeDrawer();
        App.navigateTo(btn.dataset.tab);
      });
    });

    btnLogoutDrawer?.addEventListener('click', async () => {
      closeDrawer();
      document.getElementById('btn-logout')?.click();
    });

    // Swipe to open/close — use separate variables to avoid shared-state bug
    let swipeStartX = -1;
    let swipeTracking = false;

    // Swipe LEFT inside drawer → close
    drawer?.addEventListener('touchstart', e => {
      swipeStartX = e.touches[0].clientX;
      swipeTracking = true;
    }, { passive: true });
    drawer?.addEventListener('touchend', e => {
      if (swipeTracking && swipeStartX > 0 && swipeStartX - e.changedTouches[0].clientX > 60) closeDrawer();
      swipeTracking = false;
      swipeStartX = -1;
    }, { passive: true });

    // Swipe RIGHT from left edge → open (only when drawer is closed)
    let edgeSwipeStartX = -1;
    document.addEventListener('touchstart', e => {
      if (!_drawerOpen && e.touches[0].clientX < 20) {
        edgeSwipeStartX = e.touches[0].clientX;
      } else {
        edgeSwipeStartX = -1;
      }
    }, { passive: true });
    document.addEventListener('touchend', e => {
      if (edgeSwipeStartX >= 0 && e.changedTouches[0].clientX - edgeSwipeStartX > 60) openDrawer();
      edgeSwipeStartX = -1;
    }, { passive: true });

    const origNavigateTo = App?.navigateTo?.bind(App);
    if (origNavigateTo) {
      App.navigateTo = function(tab) {
        drawer?.querySelectorAll('.drawer-nav-btn').forEach(b => {
          b.classList.toggle('active', b.dataset.tab === tab);
        });
        return origNavigateTo(tab);
      };
    }

    async function fillDrawerUser() {
      try {
        const u = await Auth.currentUser();
        if (!u) return;
        const nameEl  = document.getElementById('drawer-name');
        const statsEl = document.getElementById('drawer-stats');
        const avatarEl= document.getElementById('drawer-avatar');
        if (nameEl)  nameEl.textContent  = u.name || u.email || 'Jugador';
        if (statsEl) statsEl.textContent = `🎴 ${u.tiradas ?? 0} · 🪙 ${u.monedas ?? 0}`;
        if (avatarEl) {
          if (u.photoURL) {
            avatarEl.innerHTML = `<img src="${u.photoURL}" style="width:100%;height:100%;border-radius:50%;object-fit:cover">`;
          } else {
            avatarEl.textContent = (u.name || u.email || '?')[0].toUpperCase();
          }
        }
      } catch(e) {}
    }
    window.fillDrawerUser = fillDrawerUser;
    window.addEventListener('app:ready', fillDrawerUser);
    setTimeout(fillDrawerUser, 800);
  })();
  </script>

  <script is:inline>
    if ('serviceWorker' in navigator && location.protocol !== 'file:') {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('/worldcup-v15b-loading-fixed/sw.js').then(reg => {
          console.log('[PWA] SW registrado:', reg.scope);

          // Detectar cuando hay un nuevo SW esperando (nueva versión desplegada)
          const onNewSW = (worker) => {
            worker.addEventListener('statechange', () => {
              if (worker.state === 'installed') {
                // Hay una versión nueva lista — mostrar aviso y recargar automáticamente
                console.log('[PWA] Nueva versión disponible, actualizando...');
                // Decirle al nuevo SW que tome el control ahora
                worker.postMessage('SKIP_WAITING');
              }
            });
          };

          // Si ya hay un SW esperando al registrar (ej: página recargada sin cerrar)
          if (reg.waiting) onNewSW(reg.waiting);

          // Cuando se detecta una actualización durante la sesión
          reg.addEventListener('updatefound', () => {
            if (reg.installing) onNewSW(reg.installing);
          });

          // Cuando el nuevo SW toma el control, recargar la página para servir archivos frescos
          let refreshing = false;
          navigator.serviceWorker.addEventListener('controllerchange', () => {
            if (!refreshing) {
              refreshing = true;
              window.location.reload();
            }
          });

          // Verificar actualizaciones cada 5 minutos en segundo plano
          setInterval(() => reg.update(), 5 * 60 * 1000);

        }).catch(e => console.warn('[PWA] SW fallo:', e));
      });
    } else if (location.protocol === 'file:') {
      console.info('[PWA] SW desactivado en file:// — abre desde un servidor HTTP para PWA completo.');
    }

    // ── FWC EN VIVO — reproductor iframe directo (sin lógica dinámica) ──

    let deferredPrompt;
    window._pwaPrompt = null;

    function _showPwaProfileBtn() {
      const sec = document.getElementById('profile-pwa-section');
      if (sec) sec.style.display = 'block';
    }
    function _hidePwaProfileBtn() {
      const sec = document.getElementById('profile-pwa-section');
      if (sec) sec.style.display = 'none';
    }

    window.addEventListener('beforeinstallprompt', e => {
      e.preventDefault();
      deferredPrompt = e;
      window._pwaPrompt = e;
      const banner = document.getElementById('pwa-install-banner');
      if (banner && !localStorage.getItem('pwa-banner-dismissed')) {
        banner.style.display = 'flex';
      }
      _showPwaProfileBtn();
    });

    window.addEventListener('appinstalled', () => {
      deferredPrompt = null;
      window._pwaPrompt = null;
      _hidePwaProfileBtn();
    });

    document.getElementById('pwa-install-btn')?.addEventListener('click', async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      const { outcome } = await deferredPrompt.userChoice;
      deferredPrompt = null;
      window._pwaPrompt = null;
      document.getElementById('pwa-install-banner').style.display = 'none';
      _hidePwaProfileBtn();
    });

    document.getElementById('pwa-banner-close')?.addEventListener('click', () => {
      document.getElementById('pwa-install-banner').style.display = 'none';
      localStorage.setItem('pwa-banner-dismissed', '1');
    });

    // ── Banner Discord ──
    (function() {
      const discordBanner = document.getElementById('discord-banner');
      const discordClose  = document.getElementById('discord-banner-close');
      const LS_KEY = 'discord-banner-dismissed';
      if (discordBanner && !localStorage.getItem(LS_KEY)) {
        // Mostrar después de 1.5 s para no competir con el banner PWA
        setTimeout(() => {
          // Solo mostrar si el banner PWA no está visible
          const pwaBanner = document.getElementById('pwa-install-banner');
          const pwaVisible = pwaBanner && pwaBanner.style.display !== 'none';
          discordBanner.style.display = pwaVisible ? 'none' : 'flex';
          if (pwaVisible) {
            // Cuando el PWA se cierre, mostrar el de Discord
            const observer = new MutationObserver(() => {
              if (pwaBanner.style.display === 'none') {
                discordBanner.style.display = 'flex';
                observer.disconnect();
              }
            });
            observer.observe(pwaBanner, { attributes: true, attributeFilter: ['style'] });
          }
        }, 1500);
      }
      discordClose?.addEventListener('click', () => {
        discordBanner.style.display = 'none';
        localStorage.setItem(LS_KEY, '1');
      });
    })();

    document.getElementById('btn-install-pwa-profile')?.addEventListener('click', async () => {
      const prompt = window._pwaPrompt;
      if (!prompt) {
        Toast.warn('La instalación no está disponible. Es posible que la app ya esté instalada.');
        return;
      }
      prompt.prompt();
      const { outcome } = await prompt.userChoice;
      window._pwaPrompt = null;
      deferredPrompt = null;
      _hidePwaProfileBtn();
      if (outcome === 'accepted') Toast.success('¡App instalada exitosamente!');
    });
  </script>


</body>
