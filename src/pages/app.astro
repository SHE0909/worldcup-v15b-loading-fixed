<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover"/>
  <meta name="color-scheme" content="dark"/>
  <meta name="theme-color" content="#080c14"/>
  <meta name="mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-capable" content="yes"/>
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
  <meta name="apple-mobile-web-app-title" content="WCC UES"/>
  <meta name="description" content="Colecciona figuritas del Mundial 2026, predice partidos y gana recompensas"/>
  <title>World Cup Collector — UES</title>

  <link rel="manifest" href="/worldcup-v15b-loading-fixed/manifest.json"/>
  <link rel="icon" type="image/png" sizes="192x192" href="/worldcup-v15b-loading-fixed/icons/icon-192.png"/>
  <link rel="apple-touch-icon" href="/worldcup-v15b-loading-fixed/icons/icon-192.png"/>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow:wght@300;400;600;700&family=Barlow+Condensed:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/worldcup-v15b-loading-fixed/css/worldcup2026-theme.css"/>
  <link rel="stylesheet" href="/worldcup-v15b-loading-fixed/css/app.css"/>

  <script src="https://cdn.jsdelivr.net/npm/@twemoji/api@latest/dist/twemoji.min.js" crossorigin="anonymous" is:inline></script>

  <style>

    #tab-live .live-body {
      display: flex;
      flex-direction: column;
      align-items: center;
      width: 100%;
      padding: 0 0 1.5rem;
      box-sizing: border-box;
      overflow-x: hidden;
      gap: 1.25rem;
    }
    #tab-live .live-player-wrap {
      position: relative;
      width: 100%;
      max-width: 960px;
      margin: 0 auto;
      aspect-ratio: 16 / 9;
      overflow: hidden;
      border-radius: 10px;
      background: #000;
      box-shadow: 0 8px 32px rgba(0,0,0,0.55);
      flex-shrink: 0;
    }
    #tab-live .live-player-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      display: block;
    }
    @media (max-width: 768px) {
      #tab-live .live-body { padding: 0 0 1rem; gap: 1rem; }
      #tab-live .live-player-wrap { border-radius: 6px; }
    }
    @media (max-width: 480px) {
      #tab-live .live-body { padding: 0 0 0.75rem; gap: 0.75rem; }
      #tab-live .live-player-wrap { border-radius: 4px; box-shadow: 0 4px 16px rgba(0,0,0,0.5); }
    }

    /* ── Botón de menú flotante ── */
    .btn-hamburger-floating {
      position: fixed;
      top: 14px;
      left: 14px;
      z-index: 250;
      background: rgba(8,12,20,0.85);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.4);
    }
    .btn-hamburger-floating:hover {
      background: rgba(0,212,255,0.12);
    }

    /* ── Logo dentro del sidebar ── */
    .drawer-logo-img {
      width: 34px;
      height: 34px;
      border-radius: 50%;
      object-fit: cover;
    }
    .drawer-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    /* ── Pantalla de carga inicial ── */
    #loading-splash {
      position: fixed;
      inset: 0;
      z-index: 99999;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1rem;
      background: var(--bg-deep, #0a0e1a);
    }
    #loading-splash img.loading-ball {
      width: 84px;
      height: 84px;
      border-radius: 50%;
      object-fit: cover;
    }
  </style>
</head>
<body>

  <div id="loading-splash">
    <img src="/worldcup-v15b-loading-fixed/icons/icon-192.png" class="loading-ball" alt="WCC"/>
    <p class="loading-text">Cargando…</p>
  </div>

  <div id="pwa-install-banner" class="pwa-banner" style="display:none">
    <span>⚽ Instala WCC UES como app</span>
    <button class="btn btn-sm btn-primary" id="pwa-install-btn">Instalar</button>
    <button class="pwa-banner-close" id="pwa-banner-close">✕</button>
  </div>

  <div id="discord-banner" class="discord-banner" style="display:none">
    <svg class="discord-banner-icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
      <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
    </svg>
    <span>🏆 Sigue la Copa con nosotros — <strong>Servidor de Discord</strong></span>
    <a class="discord-banner-btn" href="https://discord.gg/qGh7hYqshf" target="_blank" rel="noopener">Unirse</a>
    <button class="pwa-banner-close" id="discord-banner-close" aria-label="Cerrar">✕</button>
  </div>

  <button class="btn-hamburger btn-hamburger-floating" id="btn-drawer-open" aria-label="Abrir menú">
    <span></span><span></span><span></span>
  </button>

  <div id="screen-app" class="screen active">

    <div id="drawer-overlay" class="drawer-overlay"></div>

    <nav id="app-drawer" class="app-drawer" role="navigation" aria-label="Menú principal">
      <div class="drawer-header">
        <img src="/worldcup-v15b-loading-fixed/icons/icon-192.png" class="drawer-logo-img" alt="WCC"/>
        <button class="drawer-close" id="btn-drawer-close" aria-label="Cerrar menú"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
      </div>
      <div class="drawer-user" id="drawer-user">
        <div class="drawer-avatar" id="drawer-avatar">?</div>
        <div class="drawer-user-info">
          <span class="drawer-user-name" id="drawer-name">Jugador</span>
          <span class="drawer-user-stats" id="drawer-stats"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg> 0 · <svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg> 0</span>
        </div>
      </div>
      <div class="drawer-nav">
        <button class="drawer-nav-btn active" data-tab="dashboard"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></span><span>Home</span></button>
        <button class="drawer-nav-btn" data-tab="stats"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg></span><span>Seguimiento</span></button>
        <button class="drawer-nav-btn" data-tab="gacha"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg></span><span>Gacha</span></button>
        <button class="drawer-nav-btn" data-tab="album"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg></span><span>Álbum</span></button>
        <button class="drawer-nav-btn" data-tab="battle"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg></span><span>Minijuegos</span></button>
        <button class="drawer-nav-btn" data-tab="exchange"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/></svg></span><span>Canjear</span></button>
        <button class="drawer-nav-btn" data-tab="predictions"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></span><span>Predicciones</span></button>
        <button class="drawer-nav-btn drawer-nav-live" data-tab="live"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg></span><span>FWC EN VIVO</span><span class="live-dot-badge"></span></button>
        <button class="drawer-nav-btn" data-tab="profile"><span class="dni"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span><span>Perfil</span></button>
      </div>
      <div class="drawer-footer">
        <button class="drawer-logout-btn" id="btn-drawer-logout"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>Cerrar sesión</button>
      </div>
    </nav>

    <header class="app-header">
      <div class="header-left"></div>
      <div class="header-center">
        <span id="header-greeting">Hola, Jugador</span>
      </div>
      <div class="header-right">
        <span class="header-stat" id="hdr-tiradas"><svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg> <strong>0</strong></span>
        <span class="header-stat" id="hdr-monedas">🪙 <strong>0</strong></span>
        <button class="btn-icon" id="btn-logout" title="Cerrar sesión"><svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></button>
      </div>
    </header>

    <nav class="app-nav">
      <button class="nav-btn active" data-tab="dashboard"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg><span>Home</span></button>
      <button class="nav-btn" data-tab="stats"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg><span>Seguimiento</span></button>
      <button class="nav-btn" data-tab="gacha"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg><span>Gacha</span></button>
      <button class="nav-btn" data-tab="album"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg><span>Álbum</span></button>
      <button class="nav-btn" data-tab="battle"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><span>Minijuegos</span></button>
      <button class="nav-btn" data-tab="exchange"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/></svg><span>Canjear</span></button>
      <button class="nav-btn" data-tab="predictions"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Predicciones</span></button>
      <button class="nav-btn nav-live" data-tab="live"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8" fill="currentColor" stroke="none"/></svg><span>En Vivo</span><span class="live-dot"></span></button>
      <button class="nav-btn" data-tab="profile"><svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg><span>Perfil</span></button>
    </nav>

    <main class="app-main">
      <section id="tab-dashboard" class="tab-section active">
        <div class="section-header">
          <h2><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>Panel Principal</h2>
          <button class="btn btn-sm" id="btn-update-stats"><svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg> Actualizar</button>
        </div>
        <div id="api-status-bar" class="api-status-bar" style="display:none;"></div>
        <div class="quick-actions">
          <button class="qa-btn" onclick="App.navigateTo('gacha')"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg><span>Tirar</span></button>
          <button class="qa-btn" onclick="App.navigateTo('battle')"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg><span>Minijuegos</span></button>
          <button class="qa-btn" onclick="App.navigateTo('exchange')"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16V4m0 0L3 8m4-4l4 4"/><path d="M17 8v12m0 0l4-4m-4 4l-4-4"/></svg><span>Canjear</span></button>
          <button class="qa-btn" onclick="App.navigateTo('predictions')"><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Predecir</span></button>
        </div>
        <div class="dashboard-grid">
          <div class="dash-sidebar">
            <div class="dash-card card-live">
              <h3><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><circle cx="12" cy="12" r="2"/><path d="M16.24 7.76a6 6 0 010 8.49m-8.48-.01a6 6 0 010-8.49m11.31-2.82a10 10 0 010 14.14m-14.14 0a10 10 0 010-14.14"/></svg>En Vivo</h3>
              <div id="live-matches" class="match-list">
                <p class="empty-state">No hay partidos en vivo ahora</p>
              </div>
            </div>
            <div class="dash-card card-standings">
              <h3><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><polyline points="8 21 12 17 16 21"/><line x1="12" y1="17" x2="12" y2="11"/><path d="M7 4H4a2 2 0 00-2 2v1a4 4 0 004 4h0a4 4 0 004-4V4H7z"/><path d="M17 4h3a2 2 0 012 2v1a4 4 0 01-4 4h0a4 4 0 01-4-4V4h3z"/><line x1="7" y1="4" x2="17" y2="4"/></svg>Tabla de Posiciones</h3>
              <div id="standings-preview"></div>
            </div>
            <div class="dash-card card-favorites">
              <h3><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>Mis Favoritos</h3>
              <div id="favorites-preview"></div>
            </div>
          </div>
          <div class="dash-main">
            <div class="dash-card card-upcoming">
              <h3><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right:6px;vertical-align:-2px"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>Próximos Partidos</h3>
              <div id="upcoming-matches" class="match-list"></div>
            </div>
          </div>
        </div>
      </section>

      <section id="tab-stats" class="tab-section">
        <div class="section-header"><h2><svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-3px;margin-right:6px"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>Estadísticas</h2></div>
        <div class="search-bar">
          <input type="text" id="search-input" placeholder="Buscar equipo..."/>
          <button class="btn btn-sm" id="btn-search">Buscar</button>
        </div>
        <div class="stats-tabs">
          <button class="stab active" data-stab="teams">Equipos</button>
          <button class="stab" data-stab="groups">Grupos A–L</button>
        </div>
        <div id="stats-content" class="stats-content"></div>
      </section>

      <section id="tab-gacha" class="tab-section">
        <div class="section-header"><h2><svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="vertical-align:-4px;margin-right:6px"><rect x="2" y="4" width="14" height="18" rx="2"/><path d="M8 22h12a2 2 0 002-2V8a2 2 0 00-2-2h-2"/></svg>Sobres</h2></div>
        <div class="gacha-center">
          <div class="sobre-stage">
            <div class="sobre-wrapper" id="sobre-wrapper">
              <div class="sobre sobre-closed" id="sobre-closed">
