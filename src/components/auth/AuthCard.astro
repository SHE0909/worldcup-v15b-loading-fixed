---
---
<div id="welcome-anim">
  <video id="welcome-video" src="/videos/login-welcome.mp4" playsinline muted></video>
</div>

<div class="auth-container">
  <div class="auth-logo">
    <img src="/icons/icon-192.png" class="logo-icon" style="width:72px;height:72px;border-radius:50%;object-fit:cover;" alt="WCC Logo"/>
    <h1 class="logo-title">FIFA WORLD CUP<br><span>COLECCION</span></h1>
    <p class="logo-sub">Universidad de El Salvador</p>
  </div>

  <div id="form-login" class="auth-form active">
    <h2>Iniciar Sesión</h2>
    <div class="form-group">
      <label>Correo institucional</label>
      <input type="email" id="login-email" placeholder="usuario@ues.edu.sv" autocomplete="email"/>
      <span class="input-error" id="login-email-err"></span>
    </div>
    <div class="form-group">
      <label>Contraseña</label>
      <div class="pass-field-wrap">
        <input type="password" id="login-pass" placeholder="••••••••" autocomplete="current-password"/>
        <button type="button" class="pass-toggle-btn" id="login-pass-toggle" aria-label="Mostrar contraseña" tabindex="-1">👁️</button>
      </div>
      <span class="input-error" id="login-pass-err"></span>
    </div>
    <button class="btn btn-primary btn-loading" id="btn-login">
      <span class="btn-text">Entrar al Mundial</span>
      <span class="btn-spinner" style="display:none">⏳</span>
    </button>
    <p class="auth-switch">¿No tienes cuenta? <a href="#" id="go-register">Regístrate</a></p>
    <p class="auth-switch" style="margin-top:0.4rem"><a href="#" id="go-transfer" style="color:#8899aa;font-size:0.78rem">¿Ya tienes cuenta en otro navegador?</a></p>
  </div>

  <div id="form-register" class="auth-form">
    <h2>Crear Cuenta</h2>
    <div class="form-group">
      <label>Nombre completo</label>
      <input type="text" id="reg-name" placeholder="Tu nombre"/>
      <span class="input-error" id="reg-name-err"></span>
    </div>
    <div class="form-group">
      <label>Correo institucional</label>
      <input type="email" id="reg-email" placeholder="usuario@ues.edu.sv"/>
      <span class="input-error" id="reg-email-err"></span>
    </div>
    <div class="form-group">
      <label>Contraseña</label>
      <div class="pass-field-wrap">
        <input type="password" id="reg-pass" placeholder="Mínimo 6 caracteres"/>
        <button type="button" class="pass-toggle-btn" id="reg-pass-toggle" aria-label="Mostrar contraseña" tabindex="-1">👁️</button>
      </div>
      <span class="input-error" id="reg-pass-err"></span>
    </div>
    <button class="btn btn-primary btn-loading" id="btn-register">
      <span class="btn-text">Crear cuenta</span>
      <span class="btn-spinner" style="display:none">⏳</span>
    </button>
    <p class="auth-switch">¿Ya tienes cuenta? <a href="#" id="go-login">Inicia sesión</a></p>
  </div>

  <div id="form-transfer" class="auth-form">
    <h2>Restaurar desde otro navegador</h2>
    <p style="font-size:0.8rem;color:#8899aa;margin-bottom:1rem;line-height:1.5">
      Ingresa tu correo y adjunta el archivo <strong>.json</strong> que exportaste desde la app. Se creará tu cuenta automáticamente con todos tus datos.
    </p>
    <div class="form-group">
      <label>Correo de la cuenta</label>
      <input type="email" id="transfer-email" placeholder="usuario@ues.edu.sv" autocomplete="email"/>
      <span class="input-error" id="transfer-email-err"></span>
    </div>
    <div class="form-group">
      <label>Nueva contraseña</label>
      <input type="password" id="transfer-pass" placeholder="Elige una contraseña nueva"/>
      <span class="input-error" id="transfer-pass-err"></span>
    </div>
    <div class="form-group">
      <label>Archivo de datos (.json)</label>
      <label class="file-drop" id="transfer-file-label">
        <span id="transfer-file-name">Toca para seleccionar tu archivo…</span>
        <input type="file" id="transfer-file" accept=".json" style="display:none"/>
      </label>
      <span class="input-error" id="transfer-file-err"></span>
    </div>
    <button class="btn btn-primary btn-loading" id="btn-transfer">
      <span class="btn-text">Restaurar cuenta</span>
      <span class="btn-spinner" style="display:none">⏳</span>
    </button>
    <p class="auth-switch"><a href="#" id="go-login-from-transfer">← Volver al inicio de sesión</a></p>
  </div>
</div>

<div id="tutorial-overlay" class="tutorial-overlay">
  <div class="tutorial-card">
    <button class="tutorial-skip" id="tutorial-skip">Saltar</button>
    <h2 id="tutorial-title">¡Bienvenido!</h2>
    <p id="tutorial-text"></p>
    <div class="tutorial-dots" id="tutorial-dots"></div>
    <div class="tutorial-actions">
      <button class="btn btn-secondary" id="tutorial-back">Atrás</button>
      <button class="btn btn-primary" id="tutorial-next">Siguiente</button>
    </div>
  </div>
</div>
