---
---
<header class="app-header">
  <div class="header-left">
    <button class="btn-hamburger-float" id="btn-drawer-open" aria-label="Abrir menú">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div class="header-center">
    <span id="header-greeting">Hola, Jugador</span>
  </div>
  <div class="header-right">
    <span class="header-stat" id="hdr-tiradas">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="2" y="3" width="14" height="18" rx="2"/><path d="M8 21h12a2 2 0 002-2V7a2 2 0 00-2-2h-2"/></svg>
      <strong>0</strong>
    </span>
    <span class="header-stat" id="hdr-monedas">🪙 <strong>0</strong></span>
    <button class="btn-icon" id="btn-logout" title="Cerrar sesión" aria-label="Cerrar sesión">
      <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
    </button>
  </div>
</header>

<style>
  .app-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height, 56px);
    background: rgba(8,12,20,0.95);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border, #1e2e45);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1rem;
    gap: 1rem;
  }
  .header-left, .header-right {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .header-center {
    flex: 1;
    text-align: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 0.95rem;
    color: var(--text-secondary, #7a8fa8);
    overflow: hidden;
    white-space: nowrap;
    text-overflow: ellipsis;
  }
  .header-stat {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 0.78rem;
    color: var(--text-secondary, #7a8fa8);
    background: var(--bg-card, #131d2e);
    border: 1px solid var(--border, #1e2e45);
    border-radius: 999px;
    padding: 2px 8px;
  }
  .header-stat strong { color: var(--text-primary, #e8f0ff); }

  .btn-hamburger-float {
    position: fixed;
    left: 14px;
    bottom: calc(var(--nav-height, 60px) + 14px);
    z-index: 250;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 46px;
    height: 46px;
    background: rgba(8,12,20,0.92);
    border: 1px solid var(--border, #1e2e45);
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(0,0,0,0.45);
    backdrop-filter: blur(8px);
    transition: background 0.2s, transform 0.2s;
  }
  .btn-hamburger-float:hover {
    background: rgba(0,212,255,0.12);
    transform: translateY(-2px);
  }
  .btn-hamburger-float span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-secondary, #7a8fa8);
    border-radius: 2px;
    transition: all 0.25s;
  }
  .btn-hamburger-float.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .btn-hamburger-float.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .btn-hamburger-float.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  @media (min-width: 769px) {
    .btn-hamburger-float { bottom: 20px; }
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255,85,102,0.12);
    border: 1px solid rgba(255,85,102,0.35);
    color: #ff8899;
    cursor: pointer;
    transition: all 0.2s;
  }
  .btn-icon:hover {
    background: rgba(255,85,102,0.25);
    border-color: #ff5566;
    color: #ff5566;
    transform: translateY(-1px);
    box-shadow: 0 0 12px rgba(255,85,102,0.3);
  }

  @media (max-width: 480px) {
    .app-header { padding: 0 0.75rem; gap: 0.5rem; }
  }
</style>
