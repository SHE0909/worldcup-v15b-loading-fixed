<div id="toast" class="toast" role="status" aria-live="polite"></div>

<style>
  .toast {
    position: fixed;
    bottom: calc(var(--nav-height, 64px) + 1rem);
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--bg-card, #131d2e);
    border: 1px solid var(--border, #1e2e45);
    border-radius: 999px;
    padding: 0.65rem 1.4rem;
    font-size: 0.85rem;
    color: var(--text-primary, #e8f0ff);
    opacity: 0;
    pointer-events: none;
    z-index: 9999;
    transition: opacity 0.25s, transform 0.25s;
    white-space: nowrap;
    max-width: 90vw;
  }
  .toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }
  .toast.success { border-color: #44ff88; color: #44ff88; }
  .toast.error   { border-color: #ff4466; color: #ff4466; }
  .toast.warn    { border-color: var(--gold, #ffd700); color: var(--gold, #ffd700); }
</style>
