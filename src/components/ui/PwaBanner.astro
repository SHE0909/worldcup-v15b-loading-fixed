<div id="pwa-install-banner" class="pwa-banner" style="display:none" role="banner">
  <span>⚽ Instala WCC UES como app</span>
  <button class="btn btn-sm btn-primary" id="pwa-install-btn">Instalar</button>
  <button class="pwa-banner-close" id="pwa-banner-close" aria-label="Cerrar">✕</button>
</div>

<style>
  .pwa-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 7000;
    background: linear-gradient(90deg, var(--bg-card, #131d2e), #1a2742);
    border-bottom: 1px solid var(--border-bright, #2a4060);
    padding: 0.6rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-primary, #e8f0ff);
  }
  .pwa-banner span { flex: 1; }
  .pwa-banner-close {
    background: none;
    border: none;
    color: var(--text-secondary, #7a8fa8);
    font-size: 1rem;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 4px;
    transition: color 0.2s;
  }
  .pwa-banner-close:hover { color: var(--text-primary, #e8f0ff); }
</style>
