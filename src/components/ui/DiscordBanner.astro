---
export interface Props {
  inviteUrl?: string;
}

const { inviteUrl = "https://discord.gg/qGh7hYqshf" } = Astro.props;
---
<div id="discord-banner" class="discord-banner" style="display:none" role="banner">
  <svg class="discord-banner-icon" viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
    <path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"/>
  </svg>
  <span>🏆 Sigue la Copa con nosotros — <strong>Servidor de Discord</strong></span>
  <a class="discord-banner-btn" href={inviteUrl} target="_blank" rel="noopener">Unirse</a>
  <button class="pwa-banner-close" id="discord-banner-close" aria-label="Cerrar">✕</button>
</div>

<style>
  .discord-banner {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 6900;
    background: linear-gradient(90deg, #23272a, #2c2f33);
    border-bottom: 1px solid #5865f2;
    padding: 0.5rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.82rem;
    color: #dcddde;
  }
  .discord-banner span { flex: 1; }
  .discord-banner strong { color: #fff; }
  .discord-banner-icon { flex-shrink: 0; color: #5865f2; }
  .discord-banner-btn {
    background: #5865f2;
    color: #fff;
    border-radius: 4px;
    padding: 0.3rem 0.8rem;
    font-size: 0.8rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    transition: background 0.2s;
  }
  .discord-banner-btn:hover { background: #4752c4; text-decoration: none; }
</style>
